{
  "name": "glance-claude-code",
  "displayName": "Glance for Claude Code",
  "description": "Multi-session Claude Code agent panel for VS Code.",
  "version": "0.0.2",
  "publisher": "hamzawaleed",
  "license": "MIT",
  "icon": "resources/icon.png",
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "ai",
    "anthropic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hamzawaleed0102/glancer-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/hamzawaleed0102/glancer-vscode/issues"
  },
  "homepage": "https://marketplace.visualstudio.com/items?itemName=hamzawaleed.glance-claude-code",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:glancer.agents"
  ],
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "node --test out/extractMarkers.test.js out/transcriptWatcher.test.js",
    "fix-pty": "node scripts/fix-pty-perms.mjs",
    "postinstall": "node scripts/fix-pty-perms.mjs",
    "vscode:prepublish": "pnpm run build"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "glancer",
          "title": "Glance",
          "icon": "resources/glancer.svg"
        }
      ]
    },
    "views": {
      "glancer": [
        {
          "id": "glancer.agents",
          "name": "Agents",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "glancer.focusPanel",
        "title": "Glance: Focus Agent Panel"
      },
      {
        "command": "glancer.newAgent",
        "title": "Glance: New Agent"
      },
      {
        "command": "glancer.killActive",
        "title": "Glance: Kill Active Agent"
      }
    ],
    "keybindings": [
      {
        "command": "glancer.focusPanel",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "glancer.newAgent",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "focusedView == glancer.agents"
      },
      {
        "command": "glancer.newAgent",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n"
      },
      {
        "command": "glancer.killActive",
        "key": "ctrl+backspace",
        "mac": "cmd+backspace",
        "when": "focusedView == glancer.agents"
      }
    ]
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty"
    ]
  }
}
